# Central color palette (Everforest dark, medium contrast).
# Exposed to all home modules as the `palette` module argument, so themed
# modules (btop, fzf, lazygit, nvim, ...) share one definition and a theme
# swap is a single-file change.
{
  _module.args.palette = {
    bg = "#2d353b";
    bgSelection = "#3d484d";
    bgBorder = "#475258";
    fg = "#d3c6aa";
    red = "#e67e80";
    brightRed = "#f85552";
    orange = "#e69875";
    yellow = "#dbbc7f";
    green = "#a7c080";
    aqua = "#83c092";
    blue = "#7fbbb3";
    purple = "#d699b6";
    grey1 = "#859289";
    grey2 = "#9da9a0";
  };
}

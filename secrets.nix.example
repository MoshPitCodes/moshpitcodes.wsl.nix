{
  username = "moshpitcodes";

  git = {
    userName = "MoshPitCodes";
    userEmail = "you@example.com";
    signingKey = "~/.ssh/id_ed25519_github.pub";
  };

  # API keys for coding agents. Leave empty strings to disable injection
  # (agents then read keys from the environment at runtime, e.g. via Doppler).
  apiKeys = {
    anthropic = "";
    openai = "";
    openrouter = "";
  };

  # NAS configuration (for modules/core/nas-mount.nix - host and share info).
  # When these are set the UGREEN NAS is mounted lazily at /mnt/ugreen-nas via
  # CIFS (noauto + x-systemd.automount, so it never blocks WSL boot). Leaving
  # them absent falls back to the defaults below (no real share), which is safe
  # but won't actually connect.
  nas = {
    host = "192.168.178.144"; # NAS IP address (mDNS is not used under WSL)
    share = "personal_folder"; # SMB/CIFS share name
  };

  # Samba credentials (for modules/core/samba.nix - credential file creation).
  # Written to /root/.secrets/samba-credentials at activation. When this block is
  # absent the activation script is skipped entirely and the mount stays inert.
  samba = {
    username = "nas-user";
    password = "nas-password";
    domain = "WORKGROUP";
  };

  # NAS-dependent options. Leave empty/commented to keep the matching modules
  # (modules/home/ssh.nix, modules/home/gpg.nix, modules/home/backup-repos.nix) inert:
  #   sshKeys        - copies private/public SSH keys into ~/.ssh with OpenSSH-safe
  #                    permissions. The GitHub SSH config expects id_ed25519_github.
  #   gpgDir         - absolute path to a backed-up .gnupg directory (gpg.nix
  #                    copies it into place on activation when set).
  #   backup.nasBackupPath - destination directory for the daily ~/Code
  #                    rsync backup (backup-repos.nix enables the timer+service
  #                    only when this is non-empty).
  #
  # sshKeys = {
  #   sourceDir = "/mnt/ugreen-nas/Coding/SecretsBackup2025/.ssh";
  #   keys = [
  #     "id_ed25519_github"
  #     "id_ed25519_proxmox"
  #     "id_ed25519_proxmox_terraform"
  #   ];
  # };
  # gpgDir = "/mnt/ugreen-nas/Coding/SecretsBackup2025/.gnupg";
  # ghConfigDir = "/mnt/ugreen-nas/Coding/SecretsBackup2025/.config/gh";
  # backup.nasBackupPath = "/mnt/ugreen-nas/Coding/Repositories";
}
